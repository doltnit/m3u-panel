DirectoryIndex index.php

# Blokuj dostęp do wrażliwych plików
<Files "channels.db">
    Require all denied
</Files>
<Files "auth.php">
    Require all denied
</Files>
<Files "update.php">
    Require all denied
</Files>
<Files "backup_cron.php">
    Require all denied
</Files>
<FilesMatch "\.log$">
    Require all denied
</FilesMatch>
<FilesMatch "\.cache$|\.videoid$">
    Require all denied
</FilesMatch>

# Blokuj katalog backupów przez HTTP (pobieranie tylko przez backup.php)
RewriteEngine On
RewriteRule ^backups/ - [F,L]
RewriteRule ^cache/ - [F,L]
RewriteRule ^([a-zA-Z0-9_-]+)\.m3u$ m3u.php?slug=$1 [L]
